{
  "version": 2,
  "installCommand": "npm ci && npm ci --prefix backend && npm ci --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/health/:path*",          "destination": "/api/index" },
    { "source": "/auth/:path*",            "destination": "/api/index" },
    { "source": "/route/:path*",           "destination": "/api/index" },
    { "source": "/trips/:path*",           "destination": "/api/index" },
    { "source": "/recommendations/:path*", "destination": "/api/index" },
    { "source": "/travel-info/:path*",     "destination": "/api/index" },
    { "source": "/flights/:path*",         "destination": "/api/index" },
    { "source": "/hotels/:path*",          "destination": "/api/index" }
  ]
}
