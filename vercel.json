{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app"
    },
    "backend": {
      "root": "backend",
      "buildCommand": "npm install && npm run build",
      "entrypoint": "dist/server.js"
    }
  },
  "rewrites": [
    { "source": "/auth(/.*)?",            "destination": { "type": "service", "service": "backend" } },
    { "source": "/route(/.*)?",           "destination": { "type": "service", "service": "backend" } },
    { "source": "/trips(/.*)?",           "destination": { "type": "service", "service": "backend" } },
    { "source": "/recommendations(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/health(/.*)?",          "destination": { "type": "service", "service": "backend" } },
    { "source": "/travel-info(/.*)?",     "destination": { "type": "service", "service": "backend" } },
    { "source": "/flights(/.*)?",         "destination": { "type": "service", "service": "backend" } },
    { "source": "/hotels(/.*)?",          "destination": { "type": "service", "service": "backend" } },
    { "source": "/(.*)",                  "destination": { "type": "service", "service": "frontend" } }
  ]
}
